#!name=Surge 信息
#!desc=显示 Surge 运行状态并支持一键重载配置
#!category=面板模块

[Panel]
SurgePro_ReloadProfile = script-name=SurgePro_ReloadProfile,update-interval=1

[Script]
SurgePro_ReloadProfile = type=generic,timeout=10,script-path=https://raw.githubusercontent.com/lylywayr/NetWork-Module/main/Surge/Surge%E4%BF%A1%E6%81%AF/SurgePro.js,argument=icon=paperplane.circle&color=#f6c970
