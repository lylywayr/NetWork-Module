name: Kelee2Egern
description: 支持可莉插件中心的插件给Egern使用; 非Loon用户切勿反馈插件任何问题，尊重原创; 插件中心网址 https://pluginhub.kelee.one, https://hub.kelee.one
author: 原作者@iKeLee

dns: {}
body_rewrites:
- response_regex:
    match: https://(?:pluginhub|hub)\.kelee\.one/(?:Lpx_)?list\.json
    find: loon://import\?plugin=(https://kelee\.one/Tool/Loon/Lpx/(.+?)\.lpx)
    replace: egern:///modules/new?url=$1
mitm:
  hostnames:
    includes:
    - pluginhub.kelee.one
    - hub.kelee.one
