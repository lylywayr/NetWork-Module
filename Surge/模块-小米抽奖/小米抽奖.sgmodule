#!name=小米抽奖
#!desc=小米商城抽奖 Cookie 获取与每日签到模块；参数默认启用，设为 # 可关闭对应脚本
#!author=MaYIHEI, lylywayr
#!icon=https://raw.githubusercontent.com/lylywayr/NetWork-Module/main/Surge/%E6%A8%A1%E5%9D%97-%E5%B0%8F%E7%B1%B3%E6%8A%BD%E5%A5%96/mishop.png
#!openUrl=https://shop.mi.com
#!arguments=lottery:"小米抽奖 Cookie",signin:"小米抽奖签到"
#!arguments-desc=lottery: 抽奖 Cookie 捕获脚本名称，设为 # 可关闭。\nsignin: 定时签到脚本名称，设为 # 可关闭。

[MITM]
hostname = %APPEND% shop-api.retail.mi.com

[Script]
{{{lottery}}} = type=http-request,pattern=^https:\/\/shop-api\.retail\.mi\.com\/mtop\/navi\/venue\/batch,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/lylywayr/NetWork-Module/main/Surge/%E6%A8%A1%E5%9D%97-%E5%B0%8F%E7%B1%B3%E6%8A%BD%E5%A5%96/milottery.js,img-url=https://raw.githubusercontent.com/lylywayr/NetWork-Module/main/Surge/%E6%A8%A1%E5%9D%97-%E5%B0%8F%E7%B1%B3%E6%8A%BD%E5%A5%96/mishop.png

{{{signin}}} = type=cron,cronexp=30 8 * * *,timeout=240,script-path=https://raw.githubusercontent.com/lylywayr/NetWork-Module/main/Surge/%E6%A8%A1%E5%9D%97-%E5%B0%8F%E7%B1%B3%E6%8A%BD%E5%A5%96/milottery.js,img-url=https://raw.githubusercontent.com/lylywayr/NetWork-Module/main/Surge/%E6%A8%A1%E5%9D%97-%E5%B0%8F%E7%B1%B3%E6%8A%BD%E5%A5%96/mishop.png
