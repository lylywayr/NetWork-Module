#!name=流媒体检测
#!desc=检测 Netflix、Disney+、YouTube 等流媒体解锁状态
#!category=面板模块
#!arguments=UPDATE_INTERVAL:7200
#!arguments-desc=[参数说明]\n1. UPDATE_INTERVAL: 面板自动刷新间隔，单位为秒。

[Panel]
stream-all = script-name=stream-all,title="流媒体检测",content="请刷新面板",update-interval={{{UPDATE_INTERVAL}}}

[Script]
stream-all = type=generic,timeout=15,script-path=https://raw.githubusercontent.com/lylywayr/NetWork-Module/main/Surge/%E9%9D%A2%E6%9D%BF-%E6%B5%81%E5%AA%92%E4%BD%93%E6%A3%80%E6%B5%8B/Stream-All.js
