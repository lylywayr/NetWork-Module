#!name=IP 检测
#!desc=查看当前节点出口 IP 与地区信息
#!category=面板模块

[Panel]
IP-Check = script-name=IP-Check,title="节点详情",content="请刷新面板",style=info,update-interval=1

[Script]
IP-Check = type=generic,timeout=3,script-path=https://raw.githubusercontent.com/lylywayr/NetWork-Module/main/Surge/IP%E6%A3%80%E6%B5%8B/IP-Check.js
